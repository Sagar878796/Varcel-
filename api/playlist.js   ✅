export default async function handler(req, res) {
  const BASE = "http://filex.me:8080";
  const USER = "000003";
  const PASS = "000003";

  try {
    const r = await fetch(
      `${BASE}/player_api.php?username=${USER}&password=${PASS}&action=get_live_streams`
    );
    const data = await r.json();

    let m3u = "#EXTM3U\n\n";

    data.forEach(ch => {
      const name = ch.name;
      const id = ch.stream_id;
      const group = ch.category_name || "Live";

      m3u += `#EXTINF:-1 group-title="${group}",${name}\n`;
      m3u += `https://node-proxy-5d7s.onrender.com/live/${id}\n\n`;
    });

    res.setHeader("Content-Type", "application/x-mpegURL");
    res.status(200).send(m3u);

  } catch (e) {
    res.status(500).send("Error loading playlist");
  }
}
